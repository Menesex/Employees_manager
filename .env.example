# Copy this file to ".env" for local development
# .env is git-ignored — this file (.env.example) is safe to commit

# Local development: SQLite (default, no setup needed — just delete this line)
# DATABASE_URL=sqlite:///./empleados.db

# Production PostgreSQL (replace with your actual connection string from Render/Supabase)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
